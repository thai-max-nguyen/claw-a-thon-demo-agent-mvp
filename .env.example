# ─── GreenNode MaaS — the agent's LLM (Q&A, narrative) ───────────────
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=            # MaaS API key (GreenNode AI Portal → API Keys)
LLM_MODEL=google/gemma-4-31b-it

# ─── Telegram — /run + /confirm bot + report delivery ───────────────
TELEGRAM_BOT_TOKEN=     # from @BotFather
TELEGRAM_GROUP_ID=      # target group/chat id

# ─── GreenNode AgentBase deploy (IAM service account) — DEPLOY ONLY ─
GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=

# Not env vars (set up separately):
#  • Confluence  → ~/.config/confluence-token  (Basic user:token)
#  • Atlas SSO   → logged-in browser session (run_mbs_growth.sh auto-logins)
#  • Zalopay CRM → be logged into office.zalopay.vn; the bot self-sources its session
