# GreenNode MaaS (OpenAI-compatible) — from AI Portal: MaaS -> API Keys
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=
LLM_MODEL=google/gemma-4-31b-it

# Per-role model assignment (quality-first, among GreenNode-ENABLED models).
# This account has 3 chat models enabled: google/gemma-4-31b-it,
# minimax/minimax-m2.5, qwen/qwen3-5-27b. (Other catalog models return 404.)
MODEL_QUESTION=google/gemma-4-31b-it
MODEL_CHAT=minimax/minimax-m2.5
MODEL_EVALUATE=google/gemma-4-31b-it

# Telegram bridge (telegram_bot.py) — keep the token secret, never commit
TELEGRAM_BOT_TOKEN=
AGENT_URL=http://127.0.0.1:8080
